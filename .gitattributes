# Auto-detect text files, normalize to LF on commit
* text=auto

# Source code: LF
*.js text eol=lf
*.jsx text eol=lf
*.css text eol=lf
*.html text eol=lf
*.json text eol=lf
*.md text eol=lf
*.py text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.mjs text eol=lf
*.cjs text eol=lf

# Config files: LF
.gitignore text eol=lf
.gitattributes text eol=lf
.env text eol=lf
.env.* text eol=lf
